---
import Layout from '../layouts/Layout.astro';
const pageTitle = "levi-x00";
---
<Layout pageTitle={pageTitle}>
    <div class="gif">
        <img src="/images/space.webp" role="presentation" width="300" height="259" decoding="async">
    </div>
    <h1>levi-x00</h1>
    <span class="badge">Cloud & DevOps Engineer</span>
    <h2>About</h2>
    <p>
        Hi, I'm Muhammad Pahlevi — a Cloud & DevOps Engineer based in Indonesia.
        I specialize in AWS infrastructure, container orchestration with EKS and ECS,
        and building secure, scalable systems using Infrastructure as Code.
    </p>
    <p>
        I hold multiple AWS certifications including Solutions Architect, Security Specialty,
        and Advanced Networking, alongside the Certified Kubernetes Administrator (CKA).
        I'm passionate about automation, GitOps, and cloud-native architecture.
    </p>
    <div class="center">
        <a href="/works/">
            <button class="btn">My Projects</button>
        </a>
    </div>
    <h2>Skills</h2>
    <div class="skills center">
        <img class="skills__img" width="46" height="46" alt="AWS" src="https://techstack-generator.vercel.app/aws-icon.svg"/>
        <img class="skills__img" width="46" height="46" alt="Kubernetes" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/kubernetes/kubernetes-original.svg"/>
        <img class="skills__img" width="46" height="46" alt="Terraform" src="https://www.vectorlogo.zone/logos/terraformio/terraformio-icon.svg"/>
        <img class="skills__img" width="46" height="46" alt="Docker" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"/>
        <img class="skills__img" width="46" height="46" alt="Python" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"/>
        <img class="skills__img" width="46" height="46" alt="Bash" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bash/bash-original.svg"/>
        <img class="skills__img" width="46" height="46" alt="Linux" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/linux/linux-original.svg"/>
        <img class="skills__img" width="46" height="46" alt="Git" src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg"/>
    </div>
    <h2>Certifications</h2>
    <div class="center">
        <a href="https://www.credly.com/earner/earned/badge/d8895a69-433b-48a5-b6f5-1603e41cb90f" target="_blank">
            <img src="https://images.credly.com/size/340x340/images/bd31ef42-d460-493e-8503-39592aaf0458/image.png" width="80" height="80" alt="AWS Certified" style="margin: 6px;" />
        </a>
        <a href="https://www.credly.com/earner/earned/badge/b8500c05-5e9c-4802-9860-11b2abcdc6b2" target="_blank">
            <img src="https://images.credly.com/size/340x340/images/2d84e428-9078-49b6-a804-13c15383d0de/image.png" width="80" height="80" alt="AWS Certified" style="margin: 6px;" />
        </a>
        <a href="https://www.credly.com/earner/earned/badge/3ef76e5e-5d82-4eef-af69-3f9d91edcd60" target="_blank">
            <img src="https://images.credly.com/size/340x340/images/53acdae5-d69f-4dda-b650-d02ed7a50dd7/image.png" width="80" height="80" alt="AWS Certified" style="margin: 6px;" />
        </a>
        <a href="https://www.credly.com/badges/a31ef899-071b-4854-9cef-058a3939b6cc/linked_in_profile" target="_blank">
            <img src="https://images.credly.com/size/680x680/images/8b8ed108-e77d-4396-ac59-2504583b9d54/cka_from_cncfsite__281_29.png" width="80" height="80" alt="CKA" style="margin: 6px;" />
        </a>
    </div>
</Layout>
